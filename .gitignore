# OpenClaw 工作空间 Git 忽略规则

# 临时文件和缓存
*.tmp
*.temp
*.cache
*.log
*.pid
*.lock

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 开发环境
.env
.env.local
.env.*.local

# 大文件/二进制文件（建议用Git LFS）
*.pdf
*.docx
*.xlsx
*.pptx
*.zip
*.tar.gz
*.jpg
*.png
*.mp4

# OpenClaw 特定
.openclaw/cache/
.openclaw/logs/
.openclaw/sessions/

# 技能中的临时文件
skills/*/__pycache__/
skills/*/.pytest_cache/
skills/*/dist/
skills/*/build/

# 记忆文件中的临时内容
memory/temp/
memory/*.tmp

# 其他
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python